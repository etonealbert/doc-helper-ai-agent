{
    "containerDefinitions": [
        {
            "name": "doc-helper-container",
            "image": "964866958896.dkr.ecr.us-east-1.amazonaws.com/doc-helper-ai-agent:latest",
            "cpu": 0,
            "memory": 512,
            "memoryReservation": 512,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp",
                    "name": "doc-helper-container-8000-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "ENABLE_MOCK_LLM",
                    "value": "false"
                },
                {
                    "name": "LLM_PROVIDER",
                    "value": "openai"
                },
                {
                    "name": "LLM_MODEL",
                    "value": "gpt-4o-mini"
                },
                {
                    "name": "EMBEDDING_MODEL",
                    "value": "text-embedding-3-small"
                },
                {
                    "name": "CRM_PROVIDER",
                    "value": "dynamodb"
                },
                {
                    "name": "DYNAMODB_TABLE_NAME",
                    "value": "doc-helper-records"
                },
                {
                    "name": "AWS_REGION",
                    "value": "us-east-1"
                },
                {
                    "name": "CRM_RECORD_TTL_DAYS",
                    "value": "90"
                }
            ],
            "secrets": [
                {
                    "name": "OPENAI_API_KEY",
                    "valueFrom": "arn:aws:ssm:us-east-1:964866958896:parameter/doc-helper/prod/openai-api-key"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/doc-helper-ai-task",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "doc-helper-ai-task",
    "executionRoleArn": "arn:aws:iam::964866958896:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::964866958896:role/DocHelperEcsTaskRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "enableFaultInjection": false
}
