# --- Application ---
APP_NAME=doc-helper-ai-agent
APP_ENV=local
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# --- LLM / embeddings ---
# Leave OPENAI_API_KEY empty to run fully offline in deterministic mock mode.
OPENAI_API_KEY=
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
# When true (default), the agent never calls OpenAI and uses mock LLM/retrieval.
ENABLE_MOCK_LLM=true

# --- Vector store / RAG ---
VECTOR_STORE_PROVIDER=local
RAG_TOP_K=3

# --- Paths ---
DATA_DIR=data
SAMPLE_DOCS_DIR=data/sample_docs
CHROMA_DIR=.chroma
